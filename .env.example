# ─── MySQL database ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=booking

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Express server ───────────────────────────────────────────────────────────
PORT=3001
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:5173

# ─── Vite (frontend) ─────────────────────────────────────────────────────────
# Leave blank to use Vite's built-in /api proxy during dev.
# Set to your backend URL for production builds.
VITE_API_URL=

# EMZI Nexus Brain URL for "Continue with EMZI Nexus Brain" on login
VITE_NEXUS_BRAIN_URL=https://emzinexus.com

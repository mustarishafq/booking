{
  "name": "Resource",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Resource name"
    },
    "resource_type": {
      "type": "string",
      "description": "Type of resource (e.g. Room, Car, Boat, Service, Equipment...)"
    },
    "description": {
      "type": "string"
    },
    "capacity": {
      "type": "number",
      "description": "Max occupancy / seats (optional)"
    },
    "pricing_model": {
      "type": "string",
      "enum": [
        "hourly",
        "daily",
        "flat"
      ],
      "default": "hourly",
      "description": "How this resource is priced"
    },
    "rate": {
      "type": "number",
      "description": "Rate in dollars \u2014 per hour, per day, or flat fee depending on pricing_model"
    },
    "amenities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Features / amenities"
    },
    "image_url": {
      "type": "string"
    },
    "requires_approval": {
      "type": "boolean",
      "default": true,
      "description": "When true, non-admin bookings require admin approval before confirmation"
    },
    "pic_user_id": {
      "type": "string",
      "description": "User id of the person in charge — receives notifications when this resource is booked"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "maintenance",
        "inactive"
      ],
      "default": "active"
    },
    "location": {
      "type": "string",
      "description": "Physical location or identifier"
    },
    "odometer_km": {
      "type": "number",
      "description": "Current odometer reading in km (optional, for vehicles)"
    }
  },
  "required": [
    "name",
    "resource_type",
    "rate",
    "pricing_model"
  ]
}